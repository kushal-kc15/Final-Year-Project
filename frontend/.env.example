# Frontend reads these at build time. Copy to `.env.local` for development.
# Vite exposes any var prefixed with VITE_ to the browser.
VITE_API_BASE_URL=/api
VITE_APP_NAME="Bahi-Khata"

# Google OAuth — used by @react-oauth/google. Leave empty to hide the
# "Continue with Google" button on the login screen.
VITE_GOOGLE_CLIENT_ID=
