# Frontend reads these at build time. Copy to `.env.local` for development.
# Vite exposes any variable prefixed with VITE_ to the browser.
VITE_API_BASE_URL=/api
VITE_APP_NAME="Vyapar Margadarshan"

# Google OAuth - used by @react-oauth/google.
# Leave empty to hide the "Continue with Google" button.
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
