# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=10080

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Email Settings
# For development (prints to console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production (Gmail example):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=noreply@vyaparmargadarshan.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5174

# Google Gemini API (for advanced OCR - FREE!)
# Get your API key from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-api-key-here
