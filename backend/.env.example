# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=vyapar_margadarshan.settings.development

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://vyapar_user:strong-password@localhost:5432/vyapar_margadarshan

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=10080
JWT_REMEMBER_ME_REFRESH_TOKEN_LIFETIME=43200
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
JWT_UPDATE_LAST_LOGIN=True
JWT_LEEWAY_SECONDS=0
# Optional: keep unset to use SECRET_KEY. Set a separate strong value in production if rotating app secrets.
# JWT_SIGNING_KEY=

# DRF throttle rates for auth/security endpoints
THROTTLE_AUTH_REGISTER=5/hour
THROTTLE_AUTH_LOGIN=5/minute
THROTTLE_AUTH_GOOGLE=10/minute
THROTTLE_AUTH_REFRESH=20/minute
THROTTLE_AUTH_RESEND_VERIFICATION=3/hour
THROTTLE_AUTH_VERIFY_EMAIL=10/minute
THROTTLE_AUTH_PASSWORD_RESET=5/hour
THROTTLE_AUTH_PASSWORD_RESET_CONFIRM=10/hour
THROTTLE_AUTH_PASSWORD_STRENGTH=30/minute
THROTTLE_AUTH_OTP_SEND=5/minute
THROTTLE_AUTH_OTP_VERIFY=10/minute
THROTTLE_AUTH_SECURITY_USER=10/minute

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production security toggles
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
LOG_LEVEL=INFO

# Email Settings
# For development (prints to console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production (Gmail example):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=noreply@vyaparmargadarshan.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5174

# Receipt upload validation
RECEIPT_MAX_UPLOAD_SIZE_MB=5
RECEIPT_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp

# Background jobs
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True
# Keep True for local development if Redis/Celery is not running. Use False in production.
OCR_QUEUE_FALLBACK_SYNC=True

# Google OAuth
# Use the same Google Web Client ID in both backend and frontend env files.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# OCR provider. Use nvidia for NVIDIA vision OCR, or freemodel as fallback.
OCR_PROVIDER=nvidia
OCR_MAX_OUTPUT_TOKENS=2048

# NVIDIA OCR (OpenAI-compatible vision API)
NVIDIA_API_KEY=
NVIDIA_OCR_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl
NVIDIA_OCR_TIMEOUT=120
NVIDIA_OCR_MAX_RETRIES=2
NVIDIA_OCR_RETRY_DELAY=1

# AI finance insights. Uses NVIDIA_API_KEY by default.
AI_INSIGHTS_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
AI_INSIGHTS_MODEL=moonshotai/kimi-k2.6
AI_INSIGHTS_TIMEOUT=60
AI_INSIGHTS_MAX_OUTPUT_TOKENS=900

# FreeModel OCR fallback (OpenAI-compatible vision API)
FREEMODEL_API_KEY=
FREEMODEL_BASE_URL=https://api.freemodel.dev
FREEMODEL_OCR_MODEL=gpt-5.4-mini
FREEMODEL_OCR_TIMEOUT=90
FREEMODEL_OCR_MAX_RETRIES=2
FREEMODEL_OCR_RETRY_DELAY=1
