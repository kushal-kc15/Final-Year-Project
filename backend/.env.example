```env
# =========================================================
# Vyapar Margadarshan - Backend Environment Example
# Copy this file to .env and replace placeholder values.
# Never commit your real .env file.
# =========================================================


# ---------------------------------------------------------
# Django Core
# ---------------------------------------------------------
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=vyapar_margadarshan.settings.development

ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO


# ---------------------------------------------------------
# Database
# Development: SQLite
# Production: Use PostgreSQL
# ---------------------------------------------------------
DATABASE_URL=sqlite:///db.sqlite3

# Example production PostgreSQL:
# DATABASE_URL=postgres://vyapar_user:strong-password@localhost:5432/vyapar_margadarshan


# ---------------------------------------------------------
# Frontend / CORS / CSRF
# ---------------------------------------------------------
FRONTEND_URL=http://localhost:5174

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_CREDENTIALS=False

CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174


# ---------------------------------------------------------
# JWT Authentication
# Values are in minutes.
# ---------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=10080
JWT_REMEMBER_ME_REFRESH_TOKEN_LIFETIME=43200
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
JWT_UPDATE_LAST_LOGIN=True
JWT_LEEWAY_SECONDS=0

# Optional. Leave empty to use SECRET_KEY.
# JWT_SIGNING_KEY=


# ---------------------------------------------------------
# Email
# Development: prints emails in backend terminal.
# ---------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=webmaster@localhost

# Production SMTP example:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=noreply@vyaparmargadarshan.com


# ---------------------------------------------------------
# Google OAuth
# Use the same Google Web Client ID in frontend .env.
# ---------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com


# ---------------------------------------------------------
# Receipt Uploads
# ---------------------------------------------------------
RECEIPT_MAX_UPLOAD_SIZE_MB=5
RECEIPT_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp


# ---------------------------------------------------------
# AI Receipt Scanning - Gemini
# Gemini key must stay backend-only.
# ---------------------------------------------------------
AI_RECEIPT_SCAN_ENABLED=True
GEMINI_API_KEY=your-gemini-api-key
GEMINI_RECEIPT_MODEL=gemini-2.5-flash

# Local/demo mode should usually keep this False.
# If True, Redis/Celery must be configured.
RECEIPT_OCR_USE_QUEUE=False


# ---------------------------------------------------------
# Optional Background Jobs
# Only needed if RECEIPT_OCR_USE_QUEUE=True.
# ---------------------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
# CELERY_TASK_ALWAYS_EAGER=False
# CELERY_TASK_EAGER_PROPAGATES=True
# OCR_QUEUE_FALLBACK_SYNC=True


# ---------------------------------------------------------
# Production Security
# Use these only in production with HTTPS.
# Do not enable these for normal localhost development.
# ---------------------------------------------------------
# DEBUG=False
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
```
